<!DOCTYPE html>
<html>
<head>
    <style>
        body { 
            margin: 0; 
            background: #1a1a1a; 
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            font-family: Arial, sans-serif;
            color: #00ff00;
        }
        #container {
            width: 90%;
            max-width: 500px;
            text-align: center;
        }
        h2 {
            margin: 20px 0;
        }
        canvas {
            width: 100%;
            height: 300px;
            background: #000;
            border: 2px solid #00ff00;
            display: block;
            margin: 20px 0;
        }
        #info {
            font-size: 18px;
            font-weight: bold;
            margin-top: 20px;
        }
    </style>
</head>
<body>
    <div id="container">
        <h2>📱 スマホの加速度センサー</h2>
        <canvas id="canvas"></canvas>
        <div id="info">
            <p id="status">スマホを振ってください</p>
            <p id="values" style="font-size: 14px;"></p>
        </div>
    </div>

    <script>
        const canvas = document.getElementById('canvas');
        const ctx = canvas.getContext('2d');
        const valuesDisplay = document.getElementById('values');
        const statusDisplay = document.getElementById('status');
        
        const maxDataPoints = 100;
        let dataX = [];
        let dataY = [];
        let dataZ = [];
        
        canvas.width = canvas.offsetWidth;
        canvas.height = canvas.offsetHeight;
        
        // iOS13以降の権限要求
        if (typeof DeviceMotionEvent !== 'undefined' && typeof DeviceMotionEvent.requestPermission === 'function') {
            statusDisplay.innerHTML = '📍 「許可」をタップしてください';
            statusDisplay.style.cursor = 'pointer';
            statusDisplay.addEventListener('click', () => {
                DeviceMotionEvent.requestPermission()
                    .then(permissionState => {
                        if (permissionState === 'granted') {
                            statusDisplay.innerHTML = '✅ 動作中...';
                            window.addEventListener('devicemotion', handleMotion);
                        }
                    })
                    .catch(console.error);
            });
        } else {
            // Android / iOS12以前
            window.addEventListener('devicemotion', handleMotion);
        }
        
        function handleMotion(event) {
            const accel = event.acceleration;
            
            dataX.push(accel.x || 0);
            dataY.push(accel.y || 0);
            dataZ.push(accel.z || 0);
            
            if (dataX.length > maxDataPoints) {
                dataX.shift();
                dataY.shift();
                dataZ.shift();
            }
            
            valuesDisplay.innerHTML = `
                <strong>X:</strong> ${(accel.x || 0).toFixed(2)} m/s²<br>
                <strong>Y:</strong> ${(accel.y || 0).toFixed(2)} m/s²<br>
                <strong>Z:</strong> ${(accel.z || 0).toFixed(2)} m/s²
            `;
        }
        
        function draw() {
            ctx.fillStyle = '#000';
            ctx.fillRect(0, 0, canvas.width, canvas.height);
            
            const centerY = canvas.height / 2;
            const xSpacing = canvas.width / maxDataPoints;
            
            // X軸（赤）
            ctx.strokeStyle = '#ff3333';
            ctx.lineWidth = 3;
            ctx.beginPath();
            for (let i = 0; i < dataX.length; i++) {
                const x = i * xSpacing;
                const y = centerY - (dataX[i] * 25);
                if (i === 0) ctx.moveTo(x, y);
                else ctx.lineTo(x, y);
            }
            ctx.stroke();
            
            // Y軸（緑）
            ctx.strokeStyle = '#00ff00';
            ctx.lineWidth = 3;
            ctx.beginPath();
            for (let i = 0; i < dataY.length; i++) {
                const x = i * xSpacing;
                const y = centerY - (dataY[i] * 25);
                if (i === 0) ctx.moveTo(x, y);
                else ctx.lineTo(x, y);
            }
            ctx.stroke();
            
            // Z軸（青）
            ctx.strokeStyle = '#3366ff';
            ctx.lineWidth = 3;
            ctx.beginPath();
            for (let i = 0; i < dataZ.length; i++) {
                const x = i * xSpacing;
                const y = centerY - (dataZ[i] * 25);
                if (i === 0) ctx.moveTo(x, y);
                else ctx.lineTo(x, y);
            }
            ctx.stroke();
            
            requestAnimationFrame(draw);
        }
        
        draw();
    </script>
</body>
</html>
